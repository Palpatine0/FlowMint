#!/usr/bin/env sh
cd "$(git rev-parse --show-toplevel)/web" || exit 1

# IDE / GUI Git often runs hooks with a minimal PATH (no nvm, fnm, npx).
NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
fi
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env 2>/dev/null)"
fi

# Project CLIs first. Do not prepend /usr/local before nvm — stale Node there breaks lint-staged.
export PATH="$PWD/node_modules/.bin:$PATH:/opt/homebrew/bin:/usr/local/bin"

if [ ! -x "./node_modules/.bin/lint-staged" ]; then
  echo "husky - run npm install in web/ (lint-staged missing)"
  exit 1
fi
if ! command -v node >/dev/null 2>&1; then
  echo "husky - node not on PATH; set PATH in ~/.config/husky/init.sh"
  exit 127
fi
exec ./node_modules/.bin/lint-staged
